<?xml version="1.0"?>
<package>
    <metadata>
        <id>libpjsua2maui</id>
        <title>libpjsua2maui</title>
        <version>2.17.0.2</version>
        <authors>Weslley Murdock</authors>
        <owners>Remote Code Hub</owners>
        <projectUrl>http://github.com/remotecodehub/libpjsua2maui</projectUrl>
        <description>
PJSIP bindings for .NET MAUI using version 2.17 with openh264, openssl, opus,
and bcg729.
The builds of native libraries targets iOS devices (arm64), iOS simulators (arm64, x86_64),
android devices (arm64-v8a, armeabi-v7a) and android simulators (x86, x86_64).
        </description>
        <releaseNotes>
- 🐞 BugFix: fixed the pjsip version (was using 2.16 instead of 2.17)
- 🐞 BugFix: Android targets was not found symbols throwing System.EntryPointNotFoundException
- 🧩 Improvement: Changed the namespace for libpjsua2.maui as in the pjsip maui sample
        </releaseNotes>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <license type="expression">GPL-3.0-only</license>
        <copyright>Copyright ©2026 Remote Code Hub</copyright>
        <tags>sip voip pjsip maui native pjsua2 android ios windows maccatalyst pj net</tags>
        <readme>README.md</readme>
        <iconUrl>https://raw.githubusercontent.com/remotecodehub/libpjsua2maui/main/src/icon.png</iconUrl>
        <icon>icon.png</icon>
        <repository type="git" url="https://github.com/remotecodehub/libpjsua2maui" />
        <references>
            <group targetFramework="net10.0-android36.0">
                <reference file="pjsua2maui.android.dll" />
            </group>
            <group targetFramework="net10.0-maccatalyst26.2">
                <reference file="pjsua2maui.mac.dll" />
            </group>
            <group targetFramework="net10.0-ios26.2">
                <reference file="pjsua2maui.ios.dll" />
            </group> 
            <group targetFramework="net10.0-windows10.0.19041.0">
                <reference file="pjsua2maui.win.dll" />
            </group> 
        </references>

        <dependencies>
            <group targetFramework="net10.0-android36.0" />
            <group targetFramework="net10.0-ios26.2" />
            <group targetFramework="net10.0-maccatalyst26.2" />
            <group targetFramework="net10.0-windows10.0.19041.0" />
        </dependencies>
    </metadata>

    <files>
        <file src="libpjsua2maui.targets" target="build\libpjsua2maui.targets" />
        
        <file src="libpjsua2.android.so\lib\armeabi-v7a\*" target="runtimes\android-arm\native\" />
        <file src="libpjsua2.android.so\lib\arm64-v8a\*" target="runtimes\android-arm64\native\" />
        <file src="libpjsua2.android.so\lib\x86\*" target="runtimes\android-x86\native\" />
        <file src="libpjsua2.android.so\lib\x86_64\*" target="runtimes\android-x86_64\native\" />

        <file src="libpjsua2.ios.a\lib\x86_64\libpjsua2.a"
            target="runtimes\iossimulator-x64\native\libpjsua2.a" />
        <file src="libpjsua2.ios.a\lib\arm64s\libpjsua2.a"
            target="runtimes\iossimulator-arm64\native\libpjsua2.a" />
        <file src="libpjsua2.ios.a\lib\arm64\libpjsua2.a"
            target="runtimes\ios-arm64\native\libpjsua2.a" />

        <file src="libpjsua2.mac.a\lib\x86_64\libpjsua2.a"
            target="runtimes\maccatalyst-x64\native\libpjsua2.a" />
        <file src="libpjsua2.mac.a\lib\arm64\libpjsua2.a"
            target="runtimes\maccatalyst-arm64\native\libpjsua2.a" />

        <file src="libpjsua2.win\bin\x64\pjsua2.dll"
            target="runtimes\win-x64\native\pjsua2.dll" />
        <file src="libpjsua2.win\bin\arm64\pjsua2.dll"
            target="runtimes\win-arm64\native\pjsua2.dll" />

        <file src="libpjsua2.android.so\org\pjsip\*" target="contentFiles\any\android\org\pjsip\" />

        <file src="libpjsua2maui.mac\bin\Release\net10.0-maccatalyst\pjsua2maui.mac.dll"
            target="lib\net10.0-maccatalyst26.2\" />
        <file src="libpjsua2maui.mac\bin\Release\net10.0-maccatalyst\pjsua2maui.mac.dll"
            target="ref\net10.0-maccatalyst26.2\" />
            
        <file src="libpjsua2maui.ios\bin\Release\net10.0-ios\pjsua2maui.ios.dll"
            target="lib\net10.0-ios26.2\" />
        <file src="libpjsua2maui.ios\bin\Release\net10.0-ios\pjsua2maui.ios.dll"
            target="ref\net10.0-ios26.2\" />
            
        <file src="libpjsua2maui.android\bin\Release\net10.0-android\pjsua2maui.android.dll"
            target="lib\net10.0-android36.0\" />
        <file src="libpjsua2maui.android\bin\Release\net10.0-android\pjsua2maui.android.dll"
            target="ref\net10.0-android36.0\" />
            
        <file src="libpjsua2maui.win\bin\Release\net10.0-windows10.0.19041.0\publish\pjsua2maui.win.dll" 
            target="lib\net10.0-windows10.0.19041\" />
        <file src="libpjsua2maui.win\bin\Release\net10.0-windows10.0.19041.0\publish\pjsua2maui.win.dll" 
            target="ref\net10.0-windows10.0.19041\" />

        <file src="README.md" target="." />
        <file src="..\docs\README.md" target="docs" />
        <file src="icon.png" target="." />
    </files>
</package>